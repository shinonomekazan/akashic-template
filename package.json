{
	"name": "akashic-template",
	"version": "0.1.1",
	"description": "",
	"scripts": {
		"clean": "rimraf ./script",
		"watch": "webpack -w",
		"build": "webpack",
		"build:production": "NODE_ENV=production webpack",
		"update": "akashic-cli-scan asset && akashic-cli-scan globalScripts",
		"preexport:content": "npm run build:production",
		"prettier:check": "prettier --check .",
		"prettier:write": "prettier --write .",
		"lint": "npm run prettier:check",
		"format": "npm run prettier:write",
		"start": "akashic-sandbox .",
		"serve": "akashic-cli-serve --no-open-browser",
		"export:zip": "rimraf game.zip && akashic-cli-export-zip -o game.zip -s",
		"export:html": "rimraf game && akashic-cli-export-html -o game",
		"export:content": "rimraf game.zip && akashic-cli-export-html -o ./game.zip --atsumaru",
		"test": "npm run lint && jest"
	},
	"author": "Shinonomekazan Co., Ltd.",
	"license": "MIT",
	"devDependencies": {
		"@akashic/akashic-cli-export": "^2.0.18",
		"@akashic/akashic-cli-scan": "^1.0.7",
		"@akashic/akashic-cli-serve": "^2.0.21",
		"@akashic/akashic-engine": "^3.21.3",
		"@akashic/akashic-sandbox": "^0.28.32",
		"@akashic/headless-akashic": "^4.9.0",
		"@types/jest": "^30.0.0",
		"@types/node": "^22.19.17",
		"jest": "^30.3.0",
		"prettier": "^3.8.3",
		"rimraf": "^6.1.3",
		"ts-jest": "^29.4.9",
		"ts-loader": "^9.5.7",
		"typescript": "^6.0.3",
		"webpack": "^5.106.2",
		"webpack-cli": "^7.0.2"
	}
}
